{
  "family": "node-app-task",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::054238436256:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "nodejs",
      "image": "054238436256.dkr.ecr.us-east-1.amazonaws.com/dev/nodeimages:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024"
}
